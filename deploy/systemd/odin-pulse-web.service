[Unit]
Description=Odin Pulse Web
After=network.target odin-pulse-api.service

[Service]
Type=simple
WorkingDirectory=/opt/odin-pulse
EnvironmentFile=/etc/odin-pulse/web.env
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/pnpm --filter @odin-pulse/web start
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
